// Transfer example: uses typed pointer constructors and transfer_asset syscall

seiyaku TransferDemo {
  // Public entrypoint to transfer 10 units of rose#default from alice to bob
  kotoage fn do_transfer() permission(AssetTransferRole) {
    let from = account!("6cmzPVPX8F5t35VB7wQQ68PAW8Wb1iAEr4PZHPLTQ3p69JAGG9oifzi");
    let to = account!("6cmzPVPX8dTmJWnCc8X5MpcZLb7UjrvR5Y1VdRmfj9pbb93hFbJfpLb");
    transfer_asset(from, to, asset_definition!("rose#default"), 10);
  }
}
