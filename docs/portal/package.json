{
  "name": "@iroha/dev-portal",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "prebuild": "npm run generate:volunteer-lint && npm run generate:preview-summary",
    "postbuild": "node scripts/write-checksums.mjs",
    "serve": "node scripts/serve-verified-preview.mjs",
    "serve:verified": "node scripts/serve-verified-preview.mjs",
    "swizzle": "docusaurus swizzle",
    "docs:version": "docusaurus docs:version",
    "sync-openapi": "node scripts/sync-openapi.mjs --version=current --latest",
    "tryit-proxy": "node scripts/tryit-proxy.mjs",
    "probe:tryit-proxy": "node scripts/tryit-proxy-probe.mjs",
    "release:tryit-proxy": "node scripts/tryit-proxy-release.mjs",
    "manage:tryit-proxy": "node scripts/tryit-proxy-rollback.mjs",
    "probe:portal": "node scripts/portal-probe.mjs",
    "monitor:publishing": "node scripts/monitor-publishing.mjs",
    "preview:log": "node scripts/preview-feedback-log.mjs",
    "preview:summary": "node scripts/preview-feedback-log.mjs --summary",
    "preview:digest": "node scripts/preview-feedback-digest.mjs",
    "preview:wave": "node scripts/preview-feedback-wave.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:openapi-signatures": "node scripts/check-openapi-signatures.mjs",
    "check:openapi-versions": "node scripts/verify-openapi-versions.mjs",
    "sync-i18n": "node scripts/sync-i18n.mjs",
    "sync-norito-snippets": "node scripts/sync-norito-snippets.mjs",
    "test:norito-snippets": "node --test scripts/__tests__/sync-norito-snippets.manifest.test.mjs",
    "test:tryit-proxy": "node --test scripts/__tests__/tryit-proxy.test.mjs scripts/__tests__/tryit-proxy-probe.test.mjs scripts/__tests__/tryit-proxy-release.test.mjs",
    "test:widgets": "node --test src/utils/__tests__/tryItProxy.test.mjs src/utils/__tests__/deviceAuth.test.mjs src/utils/__tests__/analytics.test.mjs plugins/norito-snippets-plugin/__tests__/watcher.test.mjs scripts/__tests__/portal-probe.test.mjs scripts/__tests__/link-checker.test.mjs scripts/__tests__/dns-cutover-plan.test.mjs scripts/__tests__/volunteer-brief-validator-lib.test.mjs scripts/__tests__/preview-feedback-log.test.mjs scripts/__tests__/preview-feedback-summary.test.mjs scripts/__tests__/preview-feedback-digest.test.mjs scripts/__tests__/preview-feedback-wave.test.mjs scripts/__tests__/docusaurus-config.test.mjs scripts/__tests__/monitor-publishing.test.mjs scripts/__tests__/check-openapi-signatures.test.mjs scripts/__tests__/openapi-signature.test.mjs scripts/__tests__/verify-openapi-versions.test.mjs",
    "generate:volunteer-lint": "node scripts/volunteer-brief-validator.mjs",
    "generate:preview-summary": "node scripts/preview-feedback-summary.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-classic": "3.9.2",
    "@docusaurus/theme-mermaid": "3.9.2",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swagger-ui-react": "5.30.2"
  },
  "devDependencies": {
    "openapi-types": "12.1.3"
  },
  "engines": {
    "node": ">=18.18"
  }
}
