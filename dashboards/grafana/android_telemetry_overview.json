{
  "title": "Android Telemetry Overview",
  "uid": "android-telemetry-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "android",
    "telemetry",
    "and7"
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(android_sdk_submission_latency_seconds_bucket, cluster)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Submission Latency P95 (5m)",
      "id": 1,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(android_sdk_submission_latency_seconds_bucket{cluster=~\"$cluster\"}[5m]))) * 1000",
          "legendFormat": "cluster={{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "metric_id": "submission_latency_p95"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Pending Queue Depth",
      "id": 2,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "android_sdk_pending_queue_depth{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "pending_queue_depth"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Offline Replay Errors (1h)",
      "id": 3,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(android_sdk_offline_replay_errors_total{cluster=~\"$cluster\"}[1h])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "offline_replay_errors"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "StrongBox Success Rate (15m)",
      "id": 4,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(android_sdk_strongbox_success_total{cluster=~\"$cluster\"}[15m])) / clamp_min(sum(rate(android_sdk_strongbox_attempt_total{cluster=~\"$cluster\"}[15m])), 1)",
          "legendFormat": "cluster={{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "metric_id": "strongbox_success_rate"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Redaction Failures (1h)",
      "id": 5,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "increase(android_telemetry_redaction_failure_total{cluster=~\"$cluster\"}[1h])",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "redaction_failures"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active Telemetry Overrides",
      "id": 6,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "android_telemetry_override_tokens_active{cluster=~\"$cluster\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "override_tokens_active"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "timeseries",
      "title": "Telemetry Export Backlog",
      "id": 7,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "targets": [
        {
          "expr": "android_telemetry_exporter_backlog{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "telemetry_export_backlog"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Crash Capture Events (1h)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "metric_id": "crash_capture_events"
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (process_state) (increase(android_crash_report_capture_total{cluster=~\"$cluster\"}[1h]))",
          "legendFormat": "{{process_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Crash Upload Outcomes (1h)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "metric_id": "crash_upload_events"
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (status) (increase(android_crash_report_upload_total{cluster=~\"$cluster\"}[1h]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
