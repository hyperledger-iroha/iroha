{
  "id": null,
  "uid": "social-follow-game",
  "title": "Social Follow Game",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Open Escrows",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "iroha_social_open_escrows"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Promo Active / Halted",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "iroha_social_campaign_active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "value": "1",
                    "text": "Promo Active"
                  },
                  {
                    "type": "special",
                    "value": "null",
                    "text": "Inactive"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "description": "Shows whether the promotion window is active; combine with Halt gauge to spot operator stops."
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Halt Switch",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "iroha_social_halted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bool"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Reward Spend (Daily + Campaign)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "iroha_social_budget_spent",
          "refId": "A",
          "legendFormat": "Daily spend"
        },
        {
          "expr": "iroha_social_campaign_spent",
          "refId": "B",
          "legendFormat": "Campaign spend"
        },
        {
          "expr": "iroha_social_campaign_cap",
          "refId": "C",
          "legendFormat": "Campaign cap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "description": "Track promo burn vs campaign cap for abuse detection and spend pacing."
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Rejections by Reason (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (reason) (increase(iroha_social_rejections_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "description": "Abuse signal: spikes in denial reasons (halt, promo window, caps, deny lists, duplicates)."
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Event Volume (Rewards / Escrows)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (event) (rate(iroha_social_events_total[5m]))",
          "legendFormat": "{{event}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}
