{
  "title": "Android SLA Readiness",
  "uid": "android-sla-readiness",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "android",
    "and8",
    "sla"
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(android_sdk_submission_latency_seconds_bucket, cluster)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Submission Latency P95 (5m)",
      "id": 1,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(android_sdk_submission_latency_seconds_bucket{cluster=~\"$cluster\"}[5m]))) * 1000",
          "legendFormat": "cluster={{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "metric_id": "submission_latency_p95"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Pending Queue Depth",
      "id": 2,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "android_sdk_pending_queue_depth{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "pending_queue_depth"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Offline Replay Errors (1h)",
      "id": 3,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(android_sdk_offline_replay_errors_total{cluster=~\"$cluster\"}[1h])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "offline_replay_errors"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "StrongBox Success Rate (15m)",
      "id": 4,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(android_sdk_strongbox_success_total{cluster=~\"$cluster\"}[15m])) / clamp_min(sum(rate(android_sdk_strongbox_attempt_total{cluster=~\"$cluster\"}[15m])), 1) * 100",
          "legendFormat": "cluster={{cluster}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "custom": {
            "metric_id": "strongbox_success_rate"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Telemetry Overrides Active",
      "id": 5,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "android_telemetry_override_tokens_active{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "telemetry_overrides_active"
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Exporter Backlog",
      "id": 6,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "android_telemetry_exporter_backlog{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "metric_id": "telemetry_exporter_backlog"
          }
        },
        "overrides": []
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "6h",
      "12h",
      "24h"
    ]
  }
}
