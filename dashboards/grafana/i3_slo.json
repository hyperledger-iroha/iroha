{
  "uid": "i3-slo",
  "title": "Iroha 3 SLOs",
  "schemaVersion": 39,
  "version": 1,
  "style": "dark",
  "refresh": "30s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Finality slot p99 (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(iroha_slot_duration_ms_bucket[5m]))",
          "legendFormat": "slot p99"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Proof verify p99 (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(zk_verify_latency_ms_bucket{status=\"Verified\"}[5m])))",
          "legendFormat": "verify p99"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Proof endpoint proxy p99 (ms)",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(zk_verify_latency_ms_bucket{status=\"Verified\"}[5m])))",
          "legendFormat": "endpoint proxy"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 120 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
