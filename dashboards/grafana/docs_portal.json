{
  "title": "Docs Portal Publishing",
  "uid": "docs-portal",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "docs",
    "sorafs",
    "portal"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "hidden": false,
    "nowDelay": ""
  },
  "templating": {
    "list": [
      {
        "name": "profile",
        "label": "Gateway profile",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(torii_sorafs_gateway_refusals_total, profile)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "hide": 0,
        "current": {
          "text": "All",
          "value": ""
        },
        "options": []
      },
      {
        "name": "reason",
        "label": "Refusal reason",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(torii_sorafs_gateway_refusals_total, reason)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "hide": 0,
        "current": {
          "text": "All",
          "value": ""
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Gateway Refusals (5m)",
      "id": 1,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(torii_sorafs_gateway_refusals_total{profile=~\"$profile\", reason=~\"$reason\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Refusal rates grouped by reason/profile to spot policy or auth regressions before publishing docs aliases."
    },
    {
      "type": "timeseries",
      "title": "Alias Cache Refresh Outcomes (5m)",
      "id": 2,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(torii_sorafs_alias_cache_refresh_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "description": "Alias cache refresh health taken from gateway telemetry; failures indicate stale proofs that would block new docs deployments."
    },
    {
      "type": "timeseries",
      "title": "Alias Proof Age p90 (1h)",
      "id": 3,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum by (le) (rate(torii_sorafs_alias_cache_age_seconds_bucket[1h])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "hidden",
          "placement": "right"
        }
      },
      "description": "90th percentile proof age; keep values well under the alias TTL to satisfy governance publishing policies."
    },
    {
      "type": "timeseries",
      "title": "Pin Registry Manifest Counts",
      "id": 4,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (status) (torii_sorafs_registry_manifests_total)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Visualises pending/approved manifests to prove that new portal artefacts cleared the registry."
    },
    {
      "type": "stat",
      "title": "Active Alias Count",
      "id": 5,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "torii_sorafs_registry_aliases_total",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "last"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "description": "Confirms the docs.sora alias exists before DNS promotion and tracks total alias footprint."
    },
    {
      "type": "stat",
      "title": "Gateway TLS Expiry (hours)",
      "id": 6,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "targets": [
        {
          "expr": "torii_sorafs_tls_cert_expiry_seconds / 3600",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "last"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "thresholds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 72
              },
              {
                "color": "green",
                "value": 168
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Warns when the publishing gateway TLS bundle approaches expiry."
    },
    {
      "type": "timeseries",
      "title": "Replication SLA Outcomes",
      "id": 7,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (outcome) (torii_sorafs_replication_sla_total)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "description": "Ensures replication SLAs stay green before and after publishing a new docs build."
    },
    {
      "type": "stat",
      "title": "Replication Backlog",
      "id": 8,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "torii_sorafs_replication_backlog_total",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "last"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "thresholds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "description": "Backlog depth must stay low before pinning docs artefacts; spikes mean replicas are still catching up."
    },
    {
      "type": "timeseries",
      "title": "Try-It Proxy Requests (5m)",
      "id": 9,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "sum by (method) (rate(tryit_proxy_requests_total[5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Request throughput grouped by method from TRYIT_PROXY_METRICS scrapes."
    },
    {
      "type": "timeseries",
      "title": "Try-It Proxy Outcomes (5m)",
      "id": 10,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(tryit_proxy_outcomes_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Outcome mix (success, rate_limited, upstream_error, etc.) derived from the Prometheus metrics endpoint."
    },
    {
      "type": "timeseries",
      "title": "Try-It Proxy Latency (5m)",
      "id": 11,
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(tryit_proxy_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(tryit_proxy_request_duration_ms_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "description": "Latency SLO panel powered by tryit_proxy_request_duration_ms_* histogram buckets."
    }
  ]
}
