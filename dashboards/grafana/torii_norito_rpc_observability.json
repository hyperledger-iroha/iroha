{
  "uid": "torii-norito-rpc",
  "title": "Torii Norito RPC Observability",
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Norito RPC 5xx error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(torii_request_failures_total{scheme=\"norito_rpc\",code=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Norito RPC P95 latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(torii_request_duration_seconds_bucket{scheme=\"norito_rpc\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Mock harness duration (CI smoke)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "torii_mock_harness_duration_ms",
          "legendFormat": "{{sdk}} · {{scenario}}",
          "interval": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Mock harness fixture versions",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "torii_mock_harness_fixture_version",
          "legendFormat": "{{sdk}} → {{fixture_version}}",
          "interval": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        }
      }
    }
  ]
}
