{
  "title": "Taikai Cache Observability",
  "uid": "taikai-cache",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "tags": [
    "taikai",
    "cache",
    "sn13"
  ],
  "templating": {
    "list": [
      {
        "name": "dataspace",
        "label": "Dataspace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(taikai_cache_hit_ratio, dataspace)",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      },
      {
        "name": "pop",
        "label": "PoP",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(taikai_cache_hit_ratio{dataspace=~\"$dataspace\"}, pop)",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      },
      {
        "name": "prefetch",
        "label": "Prefetch class",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(taikai_cache_prefetch_latency_ms_bucket{dataspace=~\"$dataspace\"}, class)",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      },
      {
        "name": "provider",
        "label": "SoraFS provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(sorafs_pdp_challenges_total, provider_id)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": ".*"
        }
      },
      {
        "name": "tier",
        "label": "PoTR tier",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(sorafs_potr_latency_ms_bucket, tier)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Cache hit ratio",
      "description": "Average taikai_cache_hit_ratio grouped by PoP.",
      "id": 1,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg by (pop) (taikai_cache_hit_ratio{dataspace=~\"$dataspace\", pop=~\"$pop\"})",
          "legendFormat": "{{pop}} hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Prefetch latency p95 (ms)",
      "description": "Histogram quantile derived from taikai_cache_prefetch_latency_ms_bucket.",
      "id": 2,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pop) (rate(taikai_cache_prefetch_latency_ms_bucket{dataspace=~\"$dataspace\", pop=~\"$pop\", class=~\"$prefetch\"}[5m])))",
          "legendFormat": "{{pop}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CAA propagation delay (s)",
      "description": "Tracks taikai_cache_caa_propagation_seconds from the time a routing update is published until all PoPs acknowledge it.",
      "id": 3,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg by (pop) (taikai_cache_caa_propagation_seconds{dataspace=~\"$dataspace\", pop=~\"$pop\"})",
          "legendFormat": "{{pop}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "PDP success rate (24h)",
      "description": "Ratio of verified PDP challenges for the selected providers.",
      "id": 4,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(sorafs_pdp_challenges_total{result=\"verified\",provider_id=~\"$provider\"}[24h])) / clamp_min(sum(rate(sorafs_pdp_challenges_total{provider_id=~\"$provider\"}[24h])), 1e-6)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.97
              },
              {
                "color": "green",
                "value": 0.995
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "PDP failures (24h)",
      "description": "Cumulative PDP failures/timeouts recorded in the last 24 hours for the selected providers.",
      "id": 5,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(sorafs_pdp_challenges_total{result=~\"failed|timeout\",provider_id=~\"$provider\"}[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "PoTR success rate (24h)",
      "description": "Share of PoTR windows that passed within the last 24 hours for the selected providers/tiers.",
      "id": 6,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "1 - clamp_max(sum(rate(sorafs_potr_failures_total{tier=~\"$tier\",provider_id=~\"$provider\"}[24h])) / clamp_min(sum(rate(sorafs_potr_latency_ms_bucket{le=\"+Inf\",tier=~\"$tier\",provider_id=~\"$provider\"}[24h])), 1e-6), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.97
              },
              {
                "color": "green",
                "value": 0.995
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "PoTR failure rate (per reason)",
      "description": "Tracks PoTR failure rate over time grouped by reason for the selected providers and tiers.",
      "id": 7,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (reason)(rate(sorafs_potr_failures_total{tier=~\"$tier\",provider_id=~\"$provider\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "showPoints": "never"
      }
    },
    {
      "type": "timeseries",
      "title": "Open shard circuits",
      "description": "Current open circuit breakers in the Taikai pull queue grouped by shard id.",
      "id": 8,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sorafs_taikai_shard_circuits_open",
          "legendFormat": "shard {{shard}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "showPoints": "never"
      }
    },
    {
      "type": "timeseries",
      "title": "Shard failovers (rate)",
      "description": "Five-minute rate of shard failovers observed by the Taikai pull queue.",
      "id": 9,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (preferred_shard, selected_shard) (rate(sorafs_taikai_shard_failovers_total[5m]))",
          "legendFormat": "{{preferred_shard}} → {{selected_shard}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "showPoints": "never"
      }
    },
    {
      "type": "timeseries",
      "title": "Taikai queue depth",
      "description": "Current Taikai pull queue backlog grouped by state.",
      "id": 10,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sorafs_taikai_queue_depth",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "showPoints": "never"
      }
    },
    {
      "type": "timeseries",
      "title": "Taikai queue events (5m rate)",
      "description": "Five-minute rate of queue events grouped by event/class (issued, hedged, rate-limited, backpressure).",
      "id": 11,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (event, class) (rate(sorafs_taikai_queue_events_total[5m]))",
          "legendFormat": "{{event}} ({{class}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "showPoints": "never"
      }
    }
  ]
}
