{
  "title": "Ministry Moderation Overview",
  "uid": "ministry-moderation",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["ministry", "moderation", "sorafs"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(moderation_requests_total, environment)",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      },
      {
        "name": "manifest",
        "label": "Manifest ID",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(moderation_requests_total{environment=~\"$environment\"}, manifest_id)",
        "refresh": 1,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (5m)",
      "id": 1,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(moderation_requests_total{environment=~\"$environment\", manifest_id=~\"$manifest\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Verdict Mix (stacked)",
      "id": 2,
      "datasource": "Prometheus",
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (verdict) (rate(moderation_requests_total{environment=~\"$environment\", manifest_id=~\"$manifest\"}[5m]))",
          "legendFormat": "{{verdict}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "min": 0
        },
        "overrides": []
      },
      "stacked": true
    },
    {
      "type": "timeseries",
      "title": "Latency P95 (5m)",
      "id": 3,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (manifest_id, le) (rate(moderation_inference_latency_seconds_bucket{environment=~\"$environment\", manifest_id=~\"$manifest\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Quarantine Queue Depth",
      "id": 4,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(moderation_quarantine_queue_depth{environment=~\"$environment\", manifest_id=~\"$manifest\"})",
          "legendFormat": "queue",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Model Drift Score",
      "id": 5,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg(moderation_model_drift_score{environment=~\"$environment\", manifest_id=~\"$manifest\"})",
          "legendFormat": "{{model_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Active Manifest",
      "id": 6,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "moderation_runner_manifest_info{environment=~\"$environment\", manifest_id=~\"$manifest\"}",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "string"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ]
}
