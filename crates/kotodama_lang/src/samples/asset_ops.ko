seiyaku AssetOps {
  kotoage fn execute() permission(Admin) {
    // Typed pointer‑ABI arguments via constructors
    let alice = account!("ed0120AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA@wonderland");
    let bob = account!("ed0120BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB@wonderland");
    let coin = asset_definition!("coin#wonder");
    mint_asset(
      alice,
      coin,
      1000
    );
    transfer_asset(
      alice,
      bob,
      coin,
      500
    );
    burn_asset(
      bob,
      coin,
      100
    );
  }
}
