// Save a simple ForwardCursor-like value into account metadata at key "cursor".
// Uses sentinel defaults in host: account=authority, key="cursor", value=ForwardCursor{"sc_dummy",1}.
seiyaku QueryAssetsAndSaveCursor {
  kotoage fn run() permission(Admin) {
    set_account_detail(authority(), name!("cursor"), json!{ query: "sc_dummy", cursor: 1 });
  }
}
