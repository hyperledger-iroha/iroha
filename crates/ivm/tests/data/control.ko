// Example illustrating control flow with a loop and branches.
// Loops from `a` up to `b` and
// uses different builtins depending on the condition.
seiyaku Example {
    kotoage fn control(a, b) {
        for let i = a; i < b; ++i {
            if i == b {
                let c = poseidon2(i, b);
            } else {
                let c = valcom(i, b);
            }
        }
    }
}
