[Unit]
Description=SoraNet relay daemon
Requires=network-online.target
After=network-online.target

[Service]
User=soranet
Group=soranet
EnvironmentFile=-/etc/soranet/relay/relay.env
ExecStart=/usr/local/bin/soranet-relay --config /etc/soranet/relay/relay.json
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s
LimitNOFILE=131072
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
