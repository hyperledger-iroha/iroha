{
  "matrix_path": "configs/swift/xcframework_device_matrix.json",
  "harness_path": "scripts/ci/run_xcframework_smoke.sh",
  "pipeline_path": ".buildkite/xcframework-smoke.yml",
  "matrix": {
    "iphone_sim": "platform=iOS Simulator,name=iPhone 15",
    "ipad_sim": "platform=iOS Simulator,name=iPad (10th generation)",
    "strongbox": "platform=iOS,name=iPhone 14 Pro,udid=$IPHONE_14P_UDID",
    "mac_fallback": "platform=macOS,arch=arm64,variant=Designed for iPad"
  },
  "harness": {
    "uses_matrix_file": true,
    "uses_reader": true,
    "has_dest_defaults": true
  },
  "pipeline": {
    "devicekit": "ios14p-strongbox"
  }
}
