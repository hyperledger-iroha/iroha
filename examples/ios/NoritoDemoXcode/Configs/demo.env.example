# Norito SwiftUI demo environment defaults
# Values are read on launch; leave empty to use in-app defaults.

# Torii REST base URL (the WebSocket URL is derived from this).
TORII_NODE_URL=https://127.0.0.1:8080

# Connect session bootstrap (base64 SID + per-role tokens)
CONNECT_SESSION_ID=
CONNECT_TOKEN_APP=
CONNECT_TOKEN_WALLET=
CONNECT_CHAIN_ID=testnet
CONNECT_ROLE=app  # app | wallet

# Optional helpers for manual key entry / approvals.
CONNECT_PEER_PUB_B64=
CONNECT_SHARED_KEY_B64=
CONNECT_APPROVE_ACCOUNT_ID=
CONNECT_APPROVE_PRIVATE_KEY_B64=
CONNECT_APPROVE_SIGNATURE_B64=

# Optional: path to an iroha_config JSON/TOML file used for acceleration toggles.
# Example: NORITO_ACCEL_CONFIG_PATH=$PROJECT_DIR/Configs/acceleration.toml
NORITO_ACCEL_CONFIG_PATH=
